# BytesCop On-Premises Configuration
# Copy this file to .env and fill in the values.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_DB=bytescop
POSTGRES_USER=bytescop
POSTGRES_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=changeme-generate-a-random-string
DJANGO_ALLOWED_HOSTS=*
DJANGO_DEBUG=false

# ---------------------------------------------------------------------------
# Email (SMTP) — optional, but required for password reset, invitations, etc.
# ---------------------------------------------------------------------------
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@yourcompany.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=noreply@yourcompany.com

# ---------------------------------------------------------------------------
# Logging — logs are written to the ./logs directory on the host
# ---------------------------------------------------------------------------
# BYTESCOP_LOG_LEVEL=INFO
# DJANGO_LOG_LEVEL=WARNING

# ---------------------------------------------------------------------------
# Port — HTTPS port (change if 443 is in use). HTTP:80 always redirects to HTTPS.
# ---------------------------------------------------------------------------
BC_PORT=443

# ---------------------------------------------------------------------------
# License key — optional, unlocks Enterprise features
# ---------------------------------------------------------------------------
# BC_LICENSE_KEY=

# ============================================
# BytesCop SaaS API — Environment Variables
# Copy to .env and fill in real values
# ============================================

# --- Environment ---
# BYTESCOP_ENV=docker-prod   # docker-prod (default) | aws-test | aws-prod | dev

# --- Django ---
DJANGO_SECRET_KEY=          # REQUIRED: generate with `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`
DJANGO_ALLOWED_HOSTS=       # REQUIRED: comma-separated, e.g. "api.bytescop.com,*.elb.amazonaws.com"

# --- PostgreSQL ---
POSTGRES_DB=bytescop
POSTGRES_USER=bytescop
POSTGRES_PASSWORD=          # REQUIRED: strong password
POSTGRES_HOST=db            # Docker service name (auto-set in docker-compose); RDS endpoint for AWS
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require  # Set for RDS (require | verify-full); omit for local Docker postgres
# POSTGRES_CONN_MAX_AGE=60

# --- CORS ---
CORS_ALLOWED_ORIGINS=       # comma-separated, e.g. "https://app.bytescop.com"

# --- JWT ---
BYTESCOP_JWT_ACCESS_MINUTES=10
BYTESCOP_JWT_REFRESH_DAYS=14

# --- Storage ---
BC_STORAGE_BACKEND=local    # local or s3
BC_MAX_UPLOAD_BYTES=10485760

# S3 buckets (when BC_STORAGE_BACKEND=s3)
# BC_S3_MEDIA_BUCKET=bc-prod-tenant-media        # logos, avatars
# BC_S3_EVIDENCE_BUCKET=bc-prod-tenant-evidence   # finding attachments
# BC_S3_REGION=ap-south-1
# BC_S3_PRESIGN_SECONDS=900

# AWS Credentials (if not using IAM instance role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Logging ---
BYTESCOP_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
# BYTESCOP_LOG_MAX_BYTES=31457280   # 30 MB (default)
# BYTESCOP_LOG_BACKUP_COUNT=10      # 10 backups (default)
